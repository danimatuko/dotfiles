#!/bin/bash

CACHE_FILE="/tmp/hyprlock-weather.txt"
CACHE_TTL=600

read_cache() {
  if [ -f "$CACHE_FILE" ]; then
    now=$(date +%s)
    mtime=$(stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0)
    age=$((now - mtime))
    if [ "$age" -lt "$CACHE_TTL" ]; then
      cat "$CACHE_FILE"
      return 0
    fi
  fi
  return 1
}

fetch_weather() {
  weather=$(curl -fsS --max-time 5 "https://wttr.in/?format=%c+%t" 2>/dev/null)
  if [ -n "$weather" ]; then
    printf "%s" "$weather"
    return 0
  fi
  return 1
}

if read_cache; then
  exit 0
fi

if output=$(fetch_weather); then
  printf "%s" "$output" >"$CACHE_FILE"
  printf "%s\n" "$output"
else
  if [ -f "$CACHE_FILE" ]; then
    cat "$CACHE_FILE"
  else
    printf "Weather unavailable\n"
  fi
fi
