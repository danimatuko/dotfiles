#!/bin/bash

set -euo pipefail

themes=("catppuccin" "gruvbox" "everforest")
default_theme="catppuccin"
cache_dir="$HOME/.cache/ags-theme"
cache_file="$cache_dir/current"

is_valid_theme() {
	local candidate="$1"

	for theme in "${themes[@]}"; do
		if [[ "$theme" == "$candidate" ]]; then
			return 0
		fi
	done

	return 1
}

read_current_theme() {
	if [[ -f "$cache_file" ]]; then
		local saved
		IFS= read -r saved < "$cache_file" || true

		if is_valid_theme "$saved"; then
			echo "$saved"
			return
		fi
	fi

	echo "$default_theme"
}

write_current_theme() {
	mkdir -p "$cache_dir"
	printf "%s\n" "$1" > "$cache_file"
}

notify_ags() {
	if ! command -v ags >/dev/null 2>&1; then
		return 1
	fi

	ags request theme-set "$1" >/dev/null 2>&1
}

reload_ags() {
	if notify_ags "$1"; then
		return
	fi

	if [[ -x "$HOME/.local/bin/ags-reload" ]]; then
		echo "Warning: AGS request failed, falling back to ags-reload" >&2
		"$HOME/.local/bin/ags-reload" >/dev/null 2>&1 || true
		return
	fi

	echo "Warning: could not apply AGS theme live and ags-reload was not found" >&2
}

configure_browser_theme() {
	local profile_dir=""
	local chrome_dir=""
	local user_js=""
	local theme_source="$HOME/.cache/current-theme/firefox-userChrome.css"

	[ -f "$theme_source" ] || return 0

	for profile_dir in "$HOME/.floorp"/*.default*; do
		[ -d "$profile_dir" ] && break
	done

	[ -d "$profile_dir" ] || return 0

	chrome_dir="$profile_dir/chrome"
	user_js="$profile_dir/user.js"

	mkdir -p "$chrome_dir"

	{
		cat "$HOME/dotfiles/themes/firefox/base-userChrome.css"
		printf "\n"
		cat "$theme_source"
	} > "$chrome_dir/userChrome.css"

	touch "$user_js"
	grep -q 'toolkit.legacyUserProfileCustomizations.stylesheets' "$user_js" || \
		echo 'user_pref("toolkit.legacyUserProfileCustomizations.stylesheets", true);' >> "$user_js"

	notify-send -u normal -i applications-internet "Set Theme" "Floorp theme updated (restart Floorp to apply)"
}

apply_external_theme() {
	if [[ ! -x "$HOME/.local/bin/system-theme-set" ]]; then
		echo "Warning: $HOME/.local/bin/system-theme-set not found, only AGS theme updated" >&2
		return
	fi

	"$HOME/.local/bin/system-theme-set" "$1"
}

set_theme() {
	if ! is_valid_theme "$1"; then
		echo "Invalid theme: $1" >&2
		echo "Available: ${themes[*]}" >&2
		exit 1
	fi

	write_current_theme "$1"
	apply_external_theme "$1"
	configure_browser_theme "$1"
	reload_ags "$1"
	echo "$1"
}

list_themes() {
	printf "%s\n" "${themes[@]}"
}

cycle_theme() {
	local current next index
	current="$(read_current_theme)"
	next="$default_theme"

	for index in "${!themes[@]}"; do
		if [[ "${themes[$index]}" == "$current" ]]; then
			next="${themes[$(((index + 1) % ${#themes[@]}))]}"
			break
		fi
	done

	set_theme "$next"
}

case "${1:-current}" in
	list)
		list_themes
		;;
	current)
		read_current_theme
		;;
	set)
		if [[ $# -lt 2 ]]; then
			echo "Usage: ags-theme set <theme>" >&2
			exit 1
		fi

		set_theme "$2"
		;;
	cycle)
		cycle_theme
		;;
	*)
		echo "Usage: ags-theme {list|current|set <theme>|cycle}" >&2
		exit 1
		;;
esac
