#!/bin/bash

ROFI_THEME="$HOME/.config/rofi/layouts/clipboard.rasi"

items=$(cliphist list)
count=$(echo "$items" | wc -l)
menu=$(echo -e "🗑️ Delete Item\n🧹 Clear History\n\n${items}")

selection=$(echo "$menu" | rofi -dmenu -p "Clipboard" \
    -mesg "📋 Clipboard Manager - $count items" \
    -config "$ROFI_THEME")

case "$selection" in
    "🗑️ Delete Item")
        cliphist list | rofi -dmenu -p "Delete" -config "$ROFI_THEME" | cliphist delete
        ;;
    "🧹 Clear History")
        echo -e "Yes\nNo" | rofi -dmenu -p "Clear all?" -config "$ROFI_THEME" | grep -q "Yes" && cliphist wipe
        ;;
    "")
        exit 0
        ;;
    *)
        echo "$selection" | cliphist decode | wl-copy
        ;;
esac
