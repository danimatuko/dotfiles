#!/bin/bash

set -euo pipefail

# Get theme name from command line
THEME=$1
THEMES_DIR="$HOME/dotfiles/themes"
CURRENT_THEME="$HOME/.cache/current-theme"

echo "Switching to theme: $THEME"

# ============================================================================
# VALIDATION
# ============================================================================

if [ ! -d "$THEMES_DIR/$THEME" ]; then
    notify-send -u critical -i dialog-error "Set Theme" "Theme '$THEME' not found"
    canberra-gtk-play -i bell >/dev/null 2>&1 &
    exit 1
fi

# ============================================================================
# UPDATE THEME SYMLINK
# ============================================================================

echo "Setting up theme symlink..."
ln -sfn "$THEMES_DIR/$THEME" "$CURRENT_THEME"
sleep 0.1  # Let symlink settle

# ============================================================================
# CONFIGURE APPLICATIONS
# ============================================================================

# Rofi colors
if [ -f "$CURRENT_THEME/rofi.rasi" ]; then
    echo "Configuring Rofi..."

    mkdir -p "$HOME/.config/rofi"

    # Link colorscheme into active colors file
    ln -sfn "$CURRENT_THEME/rofi.rasi" \
        "$HOME/.config/rofi/colors.rasi"

    # Refresh rofi (close any open instance)
    pkill -u "$USER" -x rofi >/dev/null 2>&1 || true
fi

# SwayOSD colors
if [ -f "$CURRENT_THEME/swayosd.css" ]; then
    echo "Configuring SwayOSD..."
    mkdir -p "$HOME/.config/swayosd"
    ln -sfn "$CURRENT_THEME/swayosd.css" "$HOME/.config/swayosd/colors.css"
fi

# GTK theme
if [ -f "$CURRENT_THEME/gtk-theme.txt" ] && command -v gsettings &>/dev/null; then
    echo "Applying GTK theme..."
    gsettings set org.gnome.desktop.interface gtk-theme "$(cat "$CURRENT_THEME/gtk-theme.txt")"
fi

# Ghostty terminal
if [ -f "$CURRENT_THEME/ghostty.conf" ]; then
    echo "Configuring Ghostty..."
    mkdir -p "$HOME/.config/ghostty/themes"
    ln -sf "$CURRENT_THEME/ghostty.conf" "$HOME/.config/ghostty/themes/current"
fi

# Zellij terminal multiplexer
if [ -f "$CURRENT_THEME/zellij" ]; then
    echo "Configuring Zellij..."
    ZELLIJ_THEME="$(cat "$CURRENT_THEME/zellij")"
    ZELLIJ_CONFIG="$HOME/.config/zellij/config.kdl"

    if [ -f "$ZELLIJ_CONFIG" ]; then
        perl -0pi -e 's/theme\s+"[^"]+"/theme "'"$ZELLIJ_THEME"'"/' "$ZELLIJ_CONFIG"
    else
        echo "Warning: Zellij config not found at $ZELLIJ_CONFIG"
    fi
fi

# SwayNC notifications
if [ -f "$CURRENT_THEME/swaync.css" ]; then
    echo "Configuring notifications..."
    mkdir -p "$HOME/.config/swaync"
    ln -sfn "$CURRENT_THEME/swaync.css" "$HOME/.config/swaync/theme.css"
fi

# AstroVim colorscheme
echo "Configuring AstroVim..."

ASTROVIM_THEME_FILE="$HOME/.cache/current-theme/astrovim.txt"

mkdir -p "$HOME/.cache/current-theme"

# Write the selected theme name into AstroVim theme cache
echo "$THEME" > "$ASTROVIM_THEME_FILE"


# ============================================================================
# SET WALLPAPER
# ============================================================================

WALLPAPER_ROOT="${WALLPAPER_DIR:-$HOME/Pictures/wallpapers}"
BG_DIR="$WALLPAPER_ROOT/$THEME"
if [ -d "$BG_DIR" ]; then
    echo "Setting wallpaper..."

    shopt -s nullglob nocaseglob
    BG_CANDIDATES=(
        "$BG_DIR"/*.jpg
        "$BG_DIR"/*.jpeg
        "$BG_DIR"/*.png
        "$BG_DIR"/*.webp
        "$BG_DIR"/*.gif
        "$BG_DIR"/*.bmp
        "$BG_DIR"/*.avif
    )
    shopt -u nocaseglob nullglob

    if [ ${#BG_CANDIDATES[@]} -gt 0 ]; then
        IFS=$'\n' BG_CANDIDATES=($(printf '%s\n' "${BG_CANDIDATES[@]}" | sort))
        unset IFS
        BG_IMAGE="${BG_CANDIDATES[0]}"

        # Apply wallpaper with smooth transition
        awww img "$BG_IMAGE" \
            --transition-type fade \
            --transition-duration 1 \
            --transition-fps 30

        # Save for lock screen
        mkdir -p "$HOME/.cache"
        rm -f "$HOME/.cache/current-wallpaper"  # Remove old symlink/file first
        cp "$BG_IMAGE" "$HOME/.cache/current-wallpaper"
    else
        notify-send -u normal -i dialog-warning "Set Theme" "No wallpaper image found in $BG_DIR"
    fi
else
    notify-send -u normal -i dialog-warning "Set Theme" "Wallpaper directory not found: $BG_DIR"
fi

# ============================================================================
# RELOAD APPLICATIONS
# ============================================================================

echo "Reloading applications..."

# Waybar status bar
if pgrep waybar &>/dev/null; then
    killall waybar && waybar &
fi

# Hyprland window manager  
if command -v hyprctl &>/dev/null; then
    hyprctl reload
fi

# Ghostty terminal (reload config)
if pgrep ghostty &>/dev/null; then
    killall -SIGUSR2 ghostty
fi

# SwayNC notifications
if command -v swaync-client &>/dev/null && pgrep -u "$USER" -x swaync >/dev/null 2>&1; then
    sleep 0.5
    swaync-client -rs >/dev/null 2>&1 || true
fi

# SwayOSD volume/brightness display
if pgrep swayosd-server &>/dev/null; then
    killall swayosd-server
    swayosd-server &
fi

# AstroVim (reload colorscheme in running instance)
if command -v nvim &>/dev/null; then
    ASTRO_THEME=$(cat "$HOME/.cache/current-theme/astrovim.txt")
    NVIM_THEME="$ASTRO_THEME"
    NVIM_SOCKET="${NVIM_SOCKET:-/tmp/nvim.sock}"

    # Keep this in sync with config/nvim/lua/utils/theme.lua aliases
    case "$ASTRO_THEME" in
        tokyonight) NVIM_THEME="tokyodark" ;;
        gruvbox-light) NVIM_THEME="gruvbox" ;;
        gruvbox) NVIM_THEME="gruvbox-baby" ;;
    esac

    nvim --server "$NVIM_SOCKET" --remote-send "<cmd>colorscheme $NVIM_THEME<CR>" \
        >/dev/null 2>&1 || true
fi


# ============================================================================
# FINISH
# ============================================================================

sleep 0.5
echo "Theme switched successfully!"
notify-send -u normal -i preferences-desktop-wallpaper "Theme Changed" "Switched to: ${THEME:-unknown}"
canberra-gtk-play -i message >/dev/null 2>&1 &
