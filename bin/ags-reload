#!/bin/bash

set -euo pipefail

app_entry="${XDG_CONFIG_HOME:-$HOME/.config}/ags/app.ts"
timeout 2s ags quit >/dev/null 2>&1 || true
sleep 0.5

ags run "$app_entry" >/dev/null 2>&1 &
sleep 0.65

list_output="$(timeout 2s ags list 2>/dev/null || true)"

case "$list_output" in
*ags*)
	notify-send --icon=view-refresh --app-name=AGS -h boolean:transient:true "AGS" "Reload complete"
	canberra-gtk-play -i message >/dev/null 2>&1 &
	;;
*)
	notify-send --icon=dialog-error --app-name=AGS -h boolean:transient:true "AGS" "Reload failed"
	canberra-gtk-play -i bell >/dev/null 2>&1 &
	;;
esac
