profile docked-dp3 {
  output eDP-1 disable
  output DP-3 enable mode 2560x1080@59.98Hz position 0,0 scale 1.0
  exec sh -c "notify-send -i display 'Display' 'External monitor DP-3 active' -t 3000 && canberra-gtk-play -i power-plug"
}

profile docked-dp1 {
  output eDP-1 disable
  output DP-1 enable mode 2560x1080@59.98Hz position 0,0 scale 1.0
  exec sh -c "notify-send -i display 'Display' 'External monitor DP-1 active' -t 3000 && canberra-gtk-play -i power-plug"
}

profile docked-hdmi {
  output eDP-1 disable
  output HDMI-A-1 enable position 0,0 scale 1.0
  exec sh -c "notify-send -i display 'Display' 'HDMI display active' -t 3000 && canberra-gtk-play -i power-plug"
}

profile undocked {
  output eDP-1 enable mode 2880x1800@120.0 position 0,0 scale 1.5
  exec sh -c "notify-send -i computer-laptop 'Display' 'Laptop panel active' -t 3000 && canberra-gtk-play -i power-unplug"
}
