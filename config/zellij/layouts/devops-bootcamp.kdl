layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
    }

    tab name="devops-bootcamp" {
        pane split_direction="vertical" {
            pane cwd="~/Projects/techworld-with-nana" command="nvim"
            pane size="40%" cwd="~/Projects/techworld-with-nana" command="opencode"
        }
    }

    tab name="aws-ec2" {
        pane cwd="~/Projects/techworld-with-nana"
    }
}
