{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "ags/gtk4",
    "lib": [
      "ES2023"
    ],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "target": "ES2020"
  },
  "include": [
    "app.ts",
    "env.d.ts",
    "widget/**/*.ts",
    "widget/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "build",
    "astal",
    "@girs"
  ]
}
